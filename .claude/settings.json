{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/claim-contract.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/bash-protection.js",
            "timeout": 5,
            "statusMessage": "Checking command safety..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/deploy-guard.js",
            "timeout": 5,
            "statusMessage": "Checking deploy permissions..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pre-commit-gate.js",
            "timeout": 5,
            "statusMessage": "Checking commit requirements..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/prose-fact-gate-bash.js",
            "timeout": 5,
            "statusMessage": "Checking prose claims..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/cia-planning-gate.js",
            "timeout": 5,
            "statusMessage": "Checking CIA planning..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/prose-fact-gate.js",
            "timeout": 5,
            "statusMessage": "Checking prose claims..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/file-protection.js",
            "timeout": 5,
            "statusMessage": "Checking file protection..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/evidence-ledger.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/build-gate-marker.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/edit-tracker.js",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "agent",
            "prompt": "You are the fabrication verifier. Use Read to open the evidence ledger at the OS temp directory (file: claude-evidence-ledger.jsonl). Compare $ARGUMENTS.last_assistant_message against the ledger entries. Block if any hard factual claim (execution results, test status, counts, dates, versions, 'fixed/works/safe/done' language) lacks a matching ledger entry. Allow if every hard claim is either directly evidenced by a ledger entry or explicitly labeled as inferred/not verified. For ordinary chat without hard factual claims (questions, explanations, code discussion, planning), allow without checking. Return { decision: 'block', reason: 'Unsupported claims: ...' } or { decision: 'allow' }.",
            "timeout": 30,
            "model": "claude-haiku-4-5-20251001"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "agent",
            "prompt": "You are the fabrication verifier for subagent output. Use Read to open the evidence ledger at the OS temp directory (file: claude-evidence-ledger.jsonl). Compare $ARGUMENTS.last_assistant_message against it. Block if any hard factual claim lacks matching ledger evidence. Allow if claims are evidenced or labeled as inferred/not verified. For ordinary chat without hard claims, allow. Return { decision: 'block', reason: '...' } or { decision: 'allow' }.",
            "timeout": 30,
            "model": "claude-haiku-4-5-20251001"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-cleanup.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
